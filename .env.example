# Nokopē šo failu uz .env un ievieto savas vērtības:
#   cp .env.example .env

# OpenRouter API atslēga (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-tava-atslega-seit

# AI modelis (var mainīt uz jebkuru OpenRouter modeli)
MODEL=anthropic/claude-3.5-sonnet

# Sesijas šifrēšanas atslēga — ieliec garu nejaušu virkni
SECRET_KEY=nomaini-so-uz-garu-nejausu-virkni
